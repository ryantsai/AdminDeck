{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run KKTerm exe",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\src-tauri\\target\\debug\\kkterm.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "RUST_BACKTRACE",
          "value": "1"
        },
        {
          "name": "WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS",
          "value": "--remote-debugging-port=9222"
        }
      ],
      "preLaunchTask": "debug KKTerm exe"
    },
    {
      "name": "Attach KKTerm WebView2",
      "type": "msedge",
      "request": "attach",
      "port": 9222,
      "useWebView": true,
      "webRoot": "${workspaceFolder}"
    }
  ]
}
